# ---- Supabase (free tier) ----
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
# Anon key: used for login/session (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key: server-only, full access. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Anthropic (Claude API) ----
# From console.anthropic.com -> API Keys. This is the only usage cost while building.
ANTHROPIC_API_KEY=sk-ant-...

# ---- WhatsApp Cloud API (Meta) ----
# From developers.facebook.com -> your app -> WhatsApp.
# One access token for your WhatsApp Business Account (system user token recommended).
WHATSAPP_ACCESS_TOKEN=EAA...
# Any string you invent; you paste the SAME string into Meta's webhook setup.
WHATSAPP_VERIFY_TOKEN=pick-any-secret-string

# ---- Paystack (payments) ----
# From dashboard.paystack.com -> Settings -> API Keys
PAYSTACK_SECRET_KEY=sk_test_...
